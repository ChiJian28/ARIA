{
  "name": "aria-backend",
  "version": "1.0.0",
  "description": "ARIA - Autonomous RWA Intelligence Agent backend",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc && node -e \"require('fs').cpSync('src/db/migrations','dist/db/migrations',{recursive:true})\"",
    "start": "node dist/index.js",
    "test": "jest",
    "generate-keys": "ts-node scripts/agents/generate-agent-keys.ts",
    "register-agents": "ts-node scripts/agents/register-agents.ts",
    "fund-agents": "ts-node scripts/testnet/fund-agents-from-deployer.ts",
    "test-mint": "ts-node scripts/testnet/test-mint-deploy.ts",
    "fund-accounts": "ts-node scripts/testnet/fund-accounts.ts",
    "seed-rwa": "ts-node scripts/testnet/seed-test-rwa.ts",
    "generate-deployer-key": "ts-node scripts/testnet/generate-deployer-key.ts",
    "deploy-contracts": "ts-node scripts/testnet/deploy-contracts.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "axios": "^1.6.2",
    "bullmq": "^5.1.1",
    "casper-js-sdk": "^2.15.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "eventsource": "^2.0.2",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.2.0",
    "node-cron": "^4.6.0",
    "pg": "^8.11.3",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "uuid": "^14.0.1",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/eventsource": "^1.1.15",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.5",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.10.9",
    "@types/uuid": "^9.0.7",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
