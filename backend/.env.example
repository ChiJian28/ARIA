# ======================================================
# ARIA Backend Environment Configuration
# Copy this file to .env and fill in your values
# ======================================================

# ---- Server ----
PORT=3001
NODE_ENV=development
# JWT secret for API authentication (min 32 chars)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# ---- Database ----
DATABASE_URL=postgresql://user:password@localhost:5433/aria
DB_POOL_MIN=2
DB_POOL_MAX=10

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- Gemini AI (LLM for all agents) ----
# Get your key at https://aistudio.google.com/
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# ---- Casper Blockchain ----
CASPER_NODE_URL=https://node.testnet.casper.network
CASPER_SSE_URL=https://node.testnet.casper.network/events
CASPER_NETWORK_NAME=casper-test
# Deployer secret key PEM (generate with: npm run generate-deployer-key)
DEPLOYER_SECRET_KEY_PATH=./keys/deployer/secret_key.pem

# ---- Smart Contract Hashes (set after deployment) ----
# Run npm run deploy-contracts to obtain these
RWA_REGISTRY_CONTRACT_HASH=
RWA_REGISTRY_PACKAGE_HASH=
LIQUIDITY_VAULT_CONTRACT_HASH=
LIQUIDITY_VAULT_PACKAGE_HASH=
AGENT_COUNCIL_CONTRACT_HASH=
AGENT_COUNCIL_PACKAGE_HASH=
SETTLEMENT_ENGINE_CONTRACT_HASH=
SETTLEMENT_ENGINE_PACKAGE_HASH=

# ---- Agent Keys (generated by scripts/agents/generate-agent-keys.ts) ----
# Each agent has its own ED25519 key pair stored in keys/ directory
ORCHESTRATOR_KEY_PATH=./keys/orchestrator.pem
RISK_AGENT_KEY_PATH=./keys/risk-agent.pem
VALUATION_AGENT_KEY_PATH=./keys/valuation-agent.pem
COMPLIANCE_AGENT_KEY_PATH=./keys/compliance-agent.pem
SENTINEL_AGENT_KEY_PATH=./keys/sentinel-agent.pem

# ---- x402 Payment Protocol ----
# x402 wallet for paying external data providers per-call
X402_WALLET_PRIVATE_KEY=
X402_WALLET_ADDRESS=
X402_WALLET_KEY_PATH=./keys/risk-agent.pem
# Minimum balance threshold before auto top-up (in CSPR)
X402_WALLET_MIN_BALANCE=10
# true = mock providers for dev; false = real x402 HTTP calls
X402_USE_MOCK=true
# true = route placeholder provider URLs to local /api/x402-gateway
X402_LOCAL_GATEWAY=true
# Base URLs for x402-enabled data providers (example.com = uses local gateway when X402_LOCAL_GATEWAY=true)
X402_CREDIT_BUREAU_URL=https://api.creditprovider.example.com
X402_FX_RATES_URL=https://api.fxprovider.example.com
X402_KYC_PROVIDER_URL=https://api.kycprovider.example.com
X402_MARKET_DATA_URL=https://api.marketdata.example.com

# ---- CSPR.cloud ----
# Get API key at https://cspr.cloud
CSPR_CLOUD_API_KEY=your-cspr-cloud-api-key
CSPR_CLOUD_REST_URL=https://api.cspr.cloud
CSPR_CLOUD_SSE_URL=https://stream.cspr.cloud

# ---- Agent Council Config ----
# Minimum votes required for consensus (out of 4 agents)
COUNCIL_MIN_VOTES=3
# Agent vote weights (must sum to 100 or be normalized)
RISK_AGENT_WEIGHT=35
VALUATION_AGENT_WEIGHT=35
COMPLIANCE_AGENT_WEIGHT=30

# ---- Rate Limiting ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
RWA_SUBMIT_RATE_LIMIT=5

# ---- Sentinel Scheduler ----
# Cron expression for sentinel scan (default: every 5 days at midnight UTC)
SENTINEL_CRON=0 0 */5 * *
# Cron expression for settlement check (default: every 2 days at midnight UTC)
SETTLEMENT_CRON=0 0 */2 * *
# Risk delta threshold for triggering liquidation (0-1 scale)
LIQUIDATION_THRESHOLD=0.75

# ---- CORS ----
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
